{
  "name": "solid-ui-components",
  "version": "1.0.0",
  "description": "SolidJS UI Components Library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes/default.css": "./dist/themes/default.css",
    "./themes/hud.css": "./dist/themes/hud.css",
    "./styles.css": "./dist/themes/default.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 6006",
    "build": "vite build --mode production",
    "watch": "vite build --mode production --watch",
    "preview": "vite preview",
    "prepare": "npm run build"
  },
  "keywords": [
    "solidjs",
    "components",
    "ui"
  ],
  "author": "PrimeStage",
  "license": "Commercial",
  "peerDependencies": {
    "solid-js": "^1.9.0",
    "katex": "^0.16.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.10",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.4.0",
    "vite-plugin-solid": "^2.11.6"
  },
  "dependencies": {
    "katex": "^0.16.28"
  }
}
